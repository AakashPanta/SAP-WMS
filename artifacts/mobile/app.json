{
  "expo": {
    "name": "SAP WMS Mobile",
    "slug": "sapwmsmobile",
    "owner": "aakashpanta",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sapwmsmobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0050aa"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sapwmsmobile.app"
    },
    "android": {
      "package": "com.sapwmsmobile.app"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "63e8f63a-9b4c-43ff-9db1-0bd824c85249"
      }
    }
  }
}
